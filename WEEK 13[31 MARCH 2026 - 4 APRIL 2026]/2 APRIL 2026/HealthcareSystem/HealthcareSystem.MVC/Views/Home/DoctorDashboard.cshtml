@model IEnumerable<HealthcareSystem.Models.DTOs.AppointmentDto>
@{
    ViewData["Title"] = "Doctor Dashboard";
    var list = Model?.ToList() ?? new List<HealthcareSystem.Models.DTOs.AppointmentDto>();
    var today = list.Where(a => a.AppointmentDate.Date == DateTime.Today).OrderBy(a => a.AppointmentDate).ToList();
    var pending = list.Where(a => a.Status == "Pending").ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">Doctor Dashboard</h3>
        <p class="text-muted mb-0">Welcome, Dr. @ViewBag.UserName</p>
    </div>
    <span class="text-muted small"><i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("dddd, MMMM dd")</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-primary border-4">
            <div class="card-body"><h4 class="fw-bold text-primary">@list.Count</h4><p class="text-muted small mb-0">Total Patients</p></div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-warning border-4">
            <div class="card-body"><h4 class="fw-bold text-warning">@today.Count</h4><p class="text-muted small mb-0">Today's Schedule</p></div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-info border-4">
            <div class="card-body"><h4 class="fw-bold text-info">@pending.Count</h4><p class="text-muted small mb-0">Pending Review</p></div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="card border-0 shadow-sm text-center py-3 border-start border-success border-4">
            <div class="card-body"><h4 class="fw-bold text-success">@list.Count(a => a.Status == "Completed")</h4><p class="text-muted small mb-0">Completed</p></div>
        </div>
    </div>
</div>

<!-- Today's appointments -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 d-flex justify-content-between">
        <h5 class="fw-bold mb-0"><i class="bi bi-calendar-day me-2 text-primary"></i>Today's Appointments</h5>
        <a href="/Appointments" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        @if (!today.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-check fs-1 d-block mb-2 opacity-25"></i>
                <p>No appointments scheduled for today</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Time</th><th>Patient</th><th>Symptoms</th><th>Status</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in today)
                        {
                            <tr>
                                <td><span class="fw-semibold">@appt.AppointmentDate.ToString("hh:mm tt")</span></td>
                                <td>@appt.PatientName</td>
                                <td><small class="text-muted">@(appt.Symptoms ?? "—")</small></td>
                                <td>
                                    <span class="badge @(appt.Status == "Confirmed" ? "bg-success" : appt.Status == "Pending" ? "bg-warning text-dark" : appt.Status == "Completed" ? "bg-secondary" : "bg-danger")">
                                        @appt.Status
                                    </span>
                                </td>
                                <td>
                                    @if (appt.Status == "Pending")
                                    {
                                        <form asp-controller="Appointments" asp-action="UpdateStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@appt.Id" />
                                            <input type="hidden" name="status" value="Confirmed" />
                                            <button type="submit" class="btn btn-success btn-sm">Confirm</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
