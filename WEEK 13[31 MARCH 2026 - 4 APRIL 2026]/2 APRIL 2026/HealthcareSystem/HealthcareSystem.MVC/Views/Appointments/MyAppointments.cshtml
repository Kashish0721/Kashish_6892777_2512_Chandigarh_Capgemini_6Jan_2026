@model IEnumerable<HealthcareSystem.Models.DTOs.AppointmentDto>
@{
    ViewData["Title"] = "My Appointments";
    var list = Model?.ToList() ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2 text-primary"></i>My Appointments</h3>
    <a href="/Appointments/Book" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Book New</a>
</div>

@if (!list.Any())
{
    <div class="card border-0 shadow-sm text-center py-5 text-muted">
        <i class="bi bi-calendar-x fs-1 d-block mb-3 opacity-25"></i>
        <p class="mb-3">You have no appointments yet</p>
        <a href="/Appointments/Book" class="btn btn-primary">Book Your First Appointment</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var a in list.OrderByDescending(x => x.AppointmentDate))
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="fw-bold mb-0">Dr. @a.DoctorName</h6>
                                <small class="text-muted">Appointment #@a.Id</small>
                            </div>
                            @{
                                var bc = a.Status switch {
                                    "Confirmed" => "bg-success",
                                    "Pending" => "bg-warning text-dark",
                                    "Completed" => "bg-secondary",
                                    "Cancelled" => "bg-danger",
                                    _ => "bg-light text-dark"
                                };
                            }
                            <span class="badge @bc">@a.Status</span>
                        </div>

                        <div class="d-flex align-items-center gap-2 mb-2 text-muted small">
                            <i class="bi bi-calendar3"></i>
                            <span>@a.AppointmentDate.ToString("dddd, MMM dd yyyy")</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
                            <i class="bi bi-clock"></i>
                            <span>@a.AppointmentDate.ToString("hh:mm tt")</span>
                        </div>

                        @if (!string.IsNullOrEmpty(a.Symptoms))
                        {
                            <div class="bg-light rounded p-2 mb-3 small">
                                <span class="fw-semibold">Symptoms: </span>@a.Symptoms
                            </div>
                        }

                        @if (a.Fee.HasValue)
                        {
                            <div class="d-flex justify-content-between align-items-center text-muted small">
                                <span>Consultation Fee</span>
                                <span class="fw-bold text-dark">₹@a.Fee</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
