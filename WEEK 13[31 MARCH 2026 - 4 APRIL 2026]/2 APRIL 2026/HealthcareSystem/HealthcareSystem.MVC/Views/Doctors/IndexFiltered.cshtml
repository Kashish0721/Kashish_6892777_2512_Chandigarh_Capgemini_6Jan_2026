@model IEnumerable<HealthcareSystem.Models.DTOs.DoctorDto>
@{
    ViewData["Title"] = "Doctors";
    var specs = ViewBag.Specializations as IEnumerable<HealthcareSystem.Models.DTOs.SpecializationDto>;
    var list = Model?.ToList() ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>Doctors</h3>
    <span class="badge bg-primary fs-6">@list.Count found</span>
</div>

<!-- Specialization filter pills -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="d-flex flex-wrap gap-2">
            <a href="/Doctors" class="btn btn-sm btn-outline-primary">All</a>
            @if (specs != null)
            {
                @foreach (var s in specs)
                {
                    <a href="/Doctors?specializationId=@s.Id"
                       class="btn btn-sm @(ViewBag.SpecializationId?.ToString() == s.Id.ToString() ? "btn-primary" : "btn-outline-primary")">
                        @s.Name
                    </a>
                }
            }
        </div>
    </div>
</div>

@if (!list.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x fs-1 d-block mb-2 opacity-25"></i>
        <p>No doctors found for this specialization</p>
        <a href="/Doctors" class="btn btn-outline-primary btn-sm">View All Doctors</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var doc in list)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100 doctor-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                 style="width:50px;height:50px;font-size:1.3rem">
                                @doc.FullName[0]
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0">Dr. @doc.FullName</h6>
                                <small class="text-muted">@doc.Email</small>
                                <div class="mt-1">
                                    @if (doc.IsAvailable)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Available</span>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (doc.Specializations.Any())
                        {
                            <div class="mb-3 d-flex flex-wrap gap-1">
                                @foreach (var spec in doc.Specializations.Take(3))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary">@spec</span>
                                }
                            </div>
                        }

                        <div class="row text-center g-2 mb-3">
                            <div class="col-4">
                                <div class="bg-light rounded p-2">
                                    <div class="fw-bold text-primary small">@(doc.YearsOfExperience ?? 0)y</div>
                                    <div class="text-muted" style="font-size:10px">Experience</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-light rounded p-2">
                                    <div class="fw-bold text-success small">@doc.TotalAppointments</div>
                                    <div class="text-muted" style="font-size:10px">Patients</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-light rounded p-2">
                                    <div class="fw-bold text-warning small">₹@(doc.ConsultationFee ?? 0)</div>
                                    <div class="text-muted" style="font-size:10px">Fee</div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="/Doctors/Details/@doc.Id" class="btn btn-outline-primary btn-sm flex-grow-1">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                            @if (Context.Session.GetString("UserRole") == "Patient" && doc.IsAvailable)
                            {
                                <a href="/Appointments/Book?doctorId=@doc.Id" class="btn btn-primary btn-sm flex-grow-1">
                                    <i class="bi bi-calendar-plus me-1"></i>Book
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
