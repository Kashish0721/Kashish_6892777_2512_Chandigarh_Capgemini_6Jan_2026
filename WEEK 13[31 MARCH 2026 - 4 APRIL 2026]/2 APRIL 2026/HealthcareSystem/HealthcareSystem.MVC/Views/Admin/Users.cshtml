@model HealthcareSystem.Models.DTOs.PagedResult<HealthcareSystem.Models.DTOs.UserDto>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-shield-check me-2 text-primary"></i>User Management</h3>
        <p class="text-muted mb-0">Manage all system users and roles</p>
    </div>
    <span class="badge bg-primary fs-6">@(Model?.TotalCount ?? 0) users</span>
</div>

<!-- Search bar -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                   placeholder="Search by name or email..." />
            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search?.ToString()))
            {
                <a href="/Admin/Users" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model?.Items == null || !Model.Items.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
                <p>No users found</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th><th>User</th><th>Email</th><th>Role</th>
                            <th>Status</th><th>Joined</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Items)
                        {
                            <tr>
                                <td><small class="text-muted">@u.Id</small></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width:34px;height:34px;font-size:13px;flex-shrink:0;
                                                    background:@(u.Role == "Admin" ? "#dc3545" : u.Role == "Doctor" ? "#198754" : "#0d6efd")">
                                            @u.FullName[0]
                                        </div>
                                        <span class="fw-semibold">@u.FullName</span>
                                    </div>
                                </td>
                                <td class="text-muted small">@u.Email</td>
                                <td>
                                    @{
                                        var roleBadge = u.Role switch {
                                            "Admin" => "bg-danger",
                                            "Doctor" => "bg-success",
                                            _ => "bg-primary"
                                        };
                                    }
                                    <span class="badge @roleBadge">@u.Role</span>
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Inactive</span>
                                    }
                                </td>
                                <td><small class="text-muted">@u.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</small></td>
                                <td>
                                    @if (u.Id.ToString() != Context.Session.GetInt32("UserId").ToString())
                                    {
                                        <form asp-controller="Admin" asp-action="DeleteUser" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete user @u.FullName?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted">You</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center p-3 border-top">
                    <small class="text-muted">Showing @Model.Items.Count of @Model.TotalCount</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?page=@(Model.Page-1)&search=@ViewBag.Search">‹</a>
                                </li>
                            }
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" href="?page=@i&search=@ViewBag.Search">@i</a>
                                </li>
                            }
                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?page=@(Model.Page+1)&search=@ViewBag.Search">›</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
