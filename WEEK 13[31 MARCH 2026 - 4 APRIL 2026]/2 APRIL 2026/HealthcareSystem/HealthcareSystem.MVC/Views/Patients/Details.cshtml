@model HealthcareSystem.Models.DTOs.PatientDto
@{
    ViewData["Title"] = "Patient Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="bi bi-person-circle me-2 text-primary"></i>Patient Details</h3>
    <div class="d-flex gap-2">
        <a href="/Patients/Edit/@Model.Id" class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a href="/Patients" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold mx-auto mb-3"
                 style="width:80px;height:80px;font-size:2rem">
                @Model.FullName[0]
            </div>
            <h5 class="fw-bold mb-1">@Model.FullName</h5>
            <p class="text-muted small mb-2">@Model.Email</p>
            <span class="badge bg-danger">@(Model.BloodGroup ?? "Blood group N/A")</span>
            <hr />
            <div class="row text-center">
                <div class="col-6">
                    <h6 class="fw-bold text-primary">@Model.TotalAppointments</h6>
                    <small class="text-muted">Appointments</small>
                </div>
                <div class="col-6">
                    <h6 class="fw-bold text-success">@(Model.Gender ?? "—")</h6>
                    <small class="text-muted">Gender</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4">
                <h5 class="fw-bold mb-0">Personal Information</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="text-muted small fw-semibold">PHONE NUMBER</label>
                        <p class="fw-semibold mb-0">@(Model.PhoneNumber ?? "Not provided")</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small fw-semibold">DATE OF BIRTH</label>
                        <p class="fw-semibold mb-0">@(Model.DateOfBirth?.ToString("MMM dd, yyyy") ?? "Not provided")</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small fw-semibold">BLOOD GROUP</label>
                        <p class="fw-semibold mb-0">@(Model.BloodGroup ?? "Not provided")</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small fw-semibold">GENDER</label>
                        <p class="fw-semibold mb-0">@(Model.Gender ?? "Not provided")</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small fw-semibold">ADDRESS</label>
                        <p class="fw-semibold mb-0">@(Model.Address ?? "Not provided")</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small fw-semibold">MEDICAL HISTORY</label>
                        <p class="fw-semibold mb-0">@(Model.MedicalHistory ?? "No medical history recorded")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
