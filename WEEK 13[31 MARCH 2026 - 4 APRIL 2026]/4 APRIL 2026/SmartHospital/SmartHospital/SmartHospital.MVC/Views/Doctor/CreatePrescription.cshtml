@model CreatePrescriptionViewModel
@{ ViewData["Title"] = "Create Prescription"; }
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card p-4">
      <h5 class="fw-bold mb-1"><i class="bi bi-prescription me-2 text-primary"></i>Create Prescription</h5>
      <p class="text-muted mb-3">Patient: <strong>@Model.PatientName</strong></p>
      <form asp-action="CreatePrescription" method="post">
        <input asp-for="AppointmentId" type="hidden"/>
        <input asp-for="PatientName" type="hidden"/>
        <div class="mb-3">
          <label class="form-label fw-semibold">Diagnosis</label>
          <input asp-for="Diagnosis" class="form-control" placeholder="e.g. Hypertension, Type 2 Diabetes"/>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Medicines <small class="text-muted">(one per line)</small></label>
          <textarea asp-for="Medicines" class="form-control" rows="5" placeholder="e.g.&#10;Tab. Metformin 500mg - 1-0-1 x 30 days&#10;Tab. Atorvastatin 10mg - 0-0-1 x 30 days"></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Medicine Charges (₹)</label>
          <input asp-for="MedicineCharges" type="number" step="0.01" class="form-control" placeholder="0.00"/>
          <small class="text-muted">This amount will be added to the bill when prescription is approved.</small>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Notes / Follow-up Instructions</label>
          <textarea asp-for="Notes" class="form-control" rows="2" placeholder="e.g. Review after 2 weeks. Avoid fatty food."></textarea>
        </div>
        <div class="alert alert-info py-2 small">
          <i class="bi bi-info-circle me-1"></i>
          After saving, go to <strong>View Prescription</strong> and click <strong>Approve & Generate Bill</strong> to create the patient's bill.
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Prescription</button>
          <a href="/Doctor/Appointments" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
