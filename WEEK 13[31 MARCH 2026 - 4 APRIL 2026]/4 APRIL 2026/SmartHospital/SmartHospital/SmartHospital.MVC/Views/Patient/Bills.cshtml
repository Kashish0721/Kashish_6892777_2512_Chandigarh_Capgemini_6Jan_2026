@model List<BillViewModel>
@{ ViewData["Title"] = "My Bills"; }
<h4 class="fw-bold mb-4"><i class="bi bi-receipt me-2 text-primary"></i>My Bills</h4>
@if (!Model.Any())
{
  <div class="card p-5 text-center">
    <i class="bi bi-receipt fs-1 text-muted"></i>
    <p class="mt-3 text-muted">No bills yet.</p>
  </div>
}
else
{
  <div class="card">
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>Bill #</th><th>Doctor</th><th>Consult Fee</th><th>Medicine</th><th>Total</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
        <tbody>
        @foreach (var b in Model)
        {
          <tr>
            <td>@b.BillId</td>
            <td>Dr. @b.DoctorName</td>
            <td>₹@b.ConsultationFee.ToString("F2")</td>
            <td>₹@b.MedicineCharges.ToString("F2")</td>
            <td class="fw-bold text-primary">₹@b.TotalAmount.ToString("F2")</td>
            <td><span class="badge @(b.PaymentStatus=="Paid"?"bg-success":"bg-warning text-dark")">@b.PaymentStatus</span></td>
            <td>@b.BilledAt.ToString("dd MMM yyyy")</td>
            <td><a href="/Patient/ViewBill/@b.AppointmentId" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
}
