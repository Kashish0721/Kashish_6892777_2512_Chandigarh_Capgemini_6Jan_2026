@model List<AppointmentViewModel>
@{ ViewData["Title"] = "Patient Dashboard"; }
@{ var name = Context.Session.GetString("UserName"); }

<div class="fade-in">
    <!-- Welcome Section -->
    <div class="mb-4">
        <h1 class="fw-bold mb-2">
            <i class="bi bi-person-heart" style="color: var(--primary); font-size: 1.8rem;"></i>
            Welcome, @name!
        </h1>
        <p class="text-muted fs-6">Manage your appointments and view your medical information.</p>
    </div>

    <!-- Stats Cards -->
    <div class="dashboard-grid mb-4">
        <div class="card stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5>Total Appointments</h5>
                    <div class="number">@Model.Count</div>
                </div>
                <i class="bi bi-calendar-check" style="font-size: 2.5rem; opacity: 0.2;"></i>
            </div>
        </div>
        <div class="card stat-card orange">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5>Completed</h5>
                    <div class="number">@Model.Count(a=>a.Status=="Completed")</div>
                </div>
                <i class="bi bi-check-circle" style="font-size: 2.5rem; opacity: 0.2;"></i>
            </div>
        </div>
        <div class="card stat-card blue">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5>Upcoming</h5>
                    <div class="number">@Model.Count(a=>a.Status=="Booked")</div>
                </div>
                <i class="bi bi-clock" style="font-size: 2.5rem; opacity: 0.2;"></i>
            </div>
        </div>
        <div class="card stat-card purple">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5>Cancelled</h5>
                    <div class="number">@Model.Count(a=>a.Status=="Cancelled")</div>
                </div>
                <i class="bi bi-x-circle" style="font-size: 2.5rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        <a href="/Patient/BookAppointment" class="btn btn-primary btn-lg">
            <i class="bi bi-calendar-plus"></i> Book New Appointment
        </a>
        <a href="/Patient/Bills" class="btn btn-outline-primary btn-lg">
            <i class="bi bi-receipt"></i> View My Bills
        </a>
    </div>

    <!-- Recent Appointments -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-clock-history me-2" style="color: var(--primary);"></i>
                Recent Appointments
            </h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-4">
                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: var(--text-secondary); opacity: 0.3;"></i>
                    <p class="text-muted mt-3">No appointments yet. <a href="/Patient/BookAppointment" class="link-primary">Book your first appointment!</a></p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Doctor</th>
                                <th>Department</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var a in Model.Take(5))
                        {
                            <tr>
                                <td>
                                    <strong>Dr. @a.DoctorName</strong>
                                </td>
                                <td>@a.DepartmentName</td>
                                <td>@a.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @{
                                        string badgeClass = a.Status switch
                                        {
                                            "Completed" => "badge-completed",
                                            "Cancelled" => "badge-cancelled",
                                            "Booked" => "badge-booked",
                                            _ => "badge-pending"
                                        };
                                    }
                                    <span class="badge @badgeClass">@a.Status</span>
                                </td>
                                <td class="text-nowrap">
                                    @if (a.HasPrescription)
                                    {
                                        <a href="/Patient/ViewPrescription?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-primary" title="View Prescription">
                                            <i class="bi bi-prescription"></i>
                                        </a>
                                    }
                                    @if (a.HasBill)
                                    {
                                        <a href="/Patient/ViewBill?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-primary" title="View Bill">
                                            <i class="bi bi-receipt"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (Model.Count > 5)
    {
        <div class="text-center mt-4">
            <a href="/Patient/Appointments" class="btn btn-outline-primary">
                <i class="bi bi-arrow-right"></i> View All Appointments
            </a>
        </div>
    }
</div>
