@model BillViewModel
@{ ViewData["Title"] = "Bill Details"; }
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4">
      <div class="text-center mb-3">
        <i class="bi bi-hospital" style="font-size:2rem;color:#1a2942;"></i>
        <h5 class="fw-bold mt-1">Smart Hospital Management System</h5>
        <p class="text-muted small">Official Receipt</p>
      </div>
      <hr/>
      <div class="row mb-2">
        <div class="col-6"><strong>Bill #:</strong> @Model.BillId</div>
        <div class="col-6"><strong>Date:</strong> @Model.BilledAt.ToString("dd MMM yyyy")</div>
      </div>
      <div class="row mb-3">
        <div class="col-6"><strong>Patient:</strong> @Model.PatientName</div>
        <div class="col-6"><strong>Doctor:</strong> Dr. @Model.DoctorName</div>
      </div>
      <hr/>
      <table class="table table-borderless">
        <tbody>
          <tr><td>Consultation Fee</td><td class="text-end">₹@Model.ConsultationFee.ToString("F2")</td></tr>
          <tr><td>Medicine Charges</td><td class="text-end">₹@Model.MedicineCharges.ToString("F2")</td></tr>
          <tr class="fw-bold border-top">
            <td>Total Amount</td>
            <td class="text-end fs-5 text-primary">₹@Model.TotalAmount.ToString("F2")</td>
          </tr>
        </tbody>
      </table>
      <hr/>
      <div class="text-center">
        <span class="badge @(Model.PaymentStatus=="Paid"?"bg-success":"bg-warning text-dark") fs-6 px-4 py-2">
          @Model.PaymentStatus
        </span>
      </div>
      <div class="d-flex justify-content-center gap-2 mt-3">
        <a href="/Patient/Bills" class="btn btn-outline-secondary">← Back</a>
        <button onclick="window.print()" class="btn btn-outline-primary"><i class="bi bi-printer me-1"></i>Print</button>
      </div>
    </div>
  </div>
</div>
