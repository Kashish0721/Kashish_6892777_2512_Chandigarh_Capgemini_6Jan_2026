@model PrescriptionViewModel
@{ ViewData["Title"] = "My Prescription"; }
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card p-4">
      <div class="d-flex justify-content-between mb-3">
        <div>
          <h5 class="fw-bold mb-1"><i class="bi bi-prescription me-2 text-primary"></i>Prescription</h5>
          <p class="text-muted mb-0">Appointment #@Model.AppointmentId &bull; @Model.CreatedAt.ToString("dd MMM yyyy")</p>
        </div>
        <span class="badge @(Model.IsApproved?"bg-success fs-6":"bg-warning text-dark fs-6")">
          @(Model.IsApproved ? "✅ Approved" : "⏳ Pending")
        </span>
      </div>
      <hr/>
      <div class="row mb-3">
        <div class="col-6"><strong>Patient:</strong> @Model.PatientName</div>
        <div class="col-6"><strong>Doctor:</strong> Dr. @Model.DoctorName</div>
      </div>
      <div class="mb-3">
        <strong>Diagnosis:</strong>
        <div class="p-2 bg-light rounded mt-1">@(Model.Diagnosis ?? "Not specified")</div>
      </div>
      <div class="mb-3">
        <strong>Prescribed Medicines:</strong>
        <pre class="p-2 bg-light rounded mt-1" style="white-space:pre-wrap;font-family:inherit;">@(Model.Medicines ?? "Not specified")</pre>
      </div>
      <div class="mb-3">
        <strong>Doctor's Notes:</strong>
        <div class="p-2 bg-light rounded mt-1">@(Model.Notes ?? "-")</div>
      </div>
      <div class="mb-3">
        <strong>Medicine Charges:</strong> <span class="text-success fw-bold">₹@Model.MedicineCharges.ToString("F2")</span>
      </div>
      @if (Model.IsApproved)
      {
        <a href="/Patient/ViewBill/@Model.AppointmentId" class="btn btn-success me-2">
          <i class="bi bi-receipt me-1"></i>View Bill
        </a>
      }
      <a href="/Patient/Appointments" class="btn btn-outline-secondary">← Back</a>
    </div>
  </div>
</div>
