@model List<AppointmentViewModel>
@{ ViewData["Title"] = "My Appointments"; }
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold"><i class="bi bi-calendar-check me-2 text-primary"></i>My Appointments</h4>
  <a href="/Patient/BookAppointment" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Book New</a>
</div>
@if (!Model.Any())
{
  <div class="card p-5 text-center">
    <i class="bi bi-calendar-x fs-1 text-muted"></i>
    <p class="mt-3 text-muted">No appointments yet. Book your first appointment!</p>
    <a href="/Patient/BookAppointment" class="btn btn-primary mx-auto" style="width:200px">Book Appointment</a>
  </div>
}
else
{
  <div class="card">
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead><tr><th>#</th><th>Doctor</th><th>Department</th><th>Date</th><th>Status</th><th>Prescription</th><th>Bill</th><th>Actions</th></tr></thead>
        <tbody>
        @foreach (var a in Model)
        {
          <tr>
            <td>@a.AppointmentId</td>
            <td>Dr. @a.DoctorName</td>
            <td>@a.DepartmentName</td>
            <td>@a.AppointmentDate.ToString("dd MMM yyyy HH:mm")</td>
            <td><span class="badge @(a.Status=="Completed"?"bg-success":a.Status=="Cancelled"?"bg-danger":"bg-primary")">@a.Status</span></td>
            <td>
              @if (a.HasPrescription)
              { <a href="/Patient/ViewPrescription?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i> View</a> }
              else { <span class="text-muted small">Not yet</span> }
            </td>
            <td>
              @if (a.HasBill)
              { <a href="/Patient/ViewBill?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-success"><i class="bi bi-receipt"></i> View</a> }
              else { <span class="text-muted small">Not yet</span> }
            </td>
            <td>
              @if (a.Status == "Booked")
              {
                <form asp-action="CancelAppointment" method="post" style="display:inline" onsubmit="return confirm('Cancel this appointment?')">
                  <input type="hidden" name="id" value="@a.AppointmentId"/>
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle"></i> Cancel</button>
                </form>
              }
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
}
