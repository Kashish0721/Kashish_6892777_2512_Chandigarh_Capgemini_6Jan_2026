<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartHospital</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Poppins', sans-serif; }
        
        /* Modern Color Scheme */
        :root {
            --primary: #00A878;
            --primary-dark: #008F6E;
            --secondary: #0066CC;
            --accent: #FF6B6B;
            --light-bg: #F8FAFC;
            --card-bg: #FFFFFF;
            --sidebar-bg: #0F2A3F;
            --sidebar-hover: #1A3A52;
            --text-primary: #1A202C;
            --text-secondary: #718096;
            --border-color: #E2E8F0;
        }
        
        body {
            background: var(--light-bg);
            color: var(--text-primary);
            transitions: background-color 0.3s ease;
        }
        
        /* Sidebar Styling */
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(180deg, var(--sidebar-bg) 0%, #132D42 100%);
            color: #fff;
            overflow-y: auto;
            box-shadow: 4px 0 12px rgba(0, 0, 0, 0.15);
            transition: all 0.3s ease;
        }
        
        .sidebar .brand {
            font-size: 1.5rem;
            font-weight: 700;
            padding: 1.5rem;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: linear-gradient(135deg, var(--primary) 0%, #00D4A3 100%);
            color: #fff;
            margin: 0;
        }
        
        .sidebar .brand i { font-size: 1.75rem; }
        
        .sidebar .user-info {
            padding: 1.25rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.2);
        }
        
        .sidebar .user-info small { color: rgba(255, 255, 255, 0.7); }
        .sidebar .user-info .user-name { font-weight: 600; font-size: 0.95rem; margin: 0.5rem 0; }
        
        .sidebar nav { padding: 0.5rem; margin-top: 0; }
        
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.7);
            padding: 0.85rem 1.25rem;
            border-radius: 8px;
            margin: 0.25rem 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 500;
            font-size: 0.95rem;
            position: relative;
        }
        
        .sidebar .nav-link i { font-size: 1.1rem; }
        
        .sidebar .nav-link:hover {
            color: #fff;
            background: var(--sidebar-hover);
            padding-left: 1.5rem;
            transform: translateX(2px);
        }
        
        .sidebar .nav-link.active {
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, #00D4A3 100%);
            box-shadow: 0 4px 12px rgba(0, 168, 120, 0.3);
        }
        
        .sidebar .logout-link { margin-top: auto; color: #FF6B6B; }
        .sidebar .logout-link:hover { background: rgba(255, 107, 107, 0.1); color: #FF8787; }
        
        /* Main Content */
        .main-content {
            padding: 2.5rem;
            flex-grow: 1;
            overflow-y: auto;
        }
        
        /* Alert Styling */
        .alert {
            border: none;
            border-radius: 10px;
            border-left: 4px solid;
            font-weight: 500;
            animation: slideDown 0.3s ease;
        }
        
        .alert-success { border-left-color: var(--primary); background: #E8F8F5; color: var(--primary-dark); }
        .alert-danger { border-left-color: var(--accent); background: #FEE; color: #C62B2B; }
        
        @@keyframes slideDown {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        
        /* Card Styling */
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--card-bg);
            border: 1px solid var(--border-color);
        }
        
        .card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
            transform: translateY(-4px);
        }
        
        .card-header {
            background: linear-gradient(135deg, #F8FAFC 0%, #EEF5FF 100%);
            border: none;
            border-bottom: 1px solid var(--border-color);
            padding: 1.5rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        
        .card-body { padding: 1.5rem; }
        
        /* Stat Cards */
        .stat-card {
            border: none;
            border-radius: 12px;
            padding: 1.75rem;
            color: #fff;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, var(--primary) 0%, #00D4A3 100%);
            box-shadow: 0 4px 15px rgba(0, 168, 120, 0.25);
            position: relative;
            overflow: hidden;
        }
        
        .stat-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }
        
        .stat-card:hover { transform: translateY(-8px); box-shadow: 0 8px 25px rgba(0, 168, 120, 0.35); }
        
        .stat-card.orange { background: linear-gradient(135deg, #FF7A59 0%, #FFB347 100%); box-shadow: 0 4px 15px rgba(255, 122, 89, 0.25); }
        .stat-card.orange:hover { box-shadow: 0 8px 25px rgba(255, 122, 89, 0.35); }
        
        .stat-card.blue { background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%); box-shadow: 0 4px 15px rgba(74, 144, 226, 0.25); }
        .stat-card.blue:hover { box-shadow: 0 8px 25px rgba(74, 144, 226, 0.35); }
        
        .stat-card.purple { background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%); box-shadow: 0 4px 15px rgba(155, 89, 182, 0.25); }
        .stat-card.purple:hover { box-shadow: 0 8px 25px rgba(155, 89, 182, 0.35); }
        
        .stat-card h5 { font-weight: 600; font-size: 0.9rem; opacity: 0.9; margin-bottom: 0.75rem; }
        .stat-card .number { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
        .stat-card .label { font-size: 0.85rem; opacity: 0.85; }
        
        /* Table Styling */
        .table {
            border-collapse: collapse;
            margin-bottom: 0;
        }
        
        .table thead th {
            background: linear-gradient(135deg, #F0F4FF 0%, #E8F0FF 100%);
            border: none;
            border-bottom: 2px solid var(--border-color);
            font-weight: 600;
            color: var(--primary-dark);
            padding: 1rem 1.25rem;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .table tbody td {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }
        
        .table tbody tr:hover { background: rgba(0, 168, 120, 0.02); }
        
        /* Badge Styling */
        .badge {
            padding: 0.5rem 0.875rem;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.8rem;
        }
        
        .badge-booked { background: #E0F2FE; color: #0369A1; }
        .badge-completed { background: #DCFCE7; color: #15803D; }
        .badge-cancelled { background: #FEE2E2; color: #991B1B; }
        .badge-approved { background: #E0F2FE; color: #0369A1; }
        .badge-pending { background: #FEF08A; color: #854D0E; }
        
        /* Button Styling */
        .btn {
            border-radius: 8px;
            padding: 0.625rem 1.25rem;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            font-size: 0.95rem;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, #00D4A3 100%);
            color: #fff;
            box-shadow: 0 4px 12px rgba(0, 168, 120, 0.3);
        }
        
        .btn-primary:hover, .btn-primary:focus {
            background: linear-gradient(135deg, var(--primary-dark) 0%, #00B887 100%);
            box-shadow: 0 6px 16px rgba(0, 168, 120, 0.4);
            transform: translateY(-2px);
            color: #fff;
        }
        
        .btn-secondary { background: #E8F0F8; color: var(--secondary); }
        .btn-secondary:hover { background: #D0E0F0; color: var(--secondary); }
        
        .btn-outline-primary {
            border: 2px solid var(--primary);
            color: var(--primary);
        }
        
        .btn-outline-primary:hover {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }
        
        /* Form Styling */
        .form-control, .form-select {
            border: 1.5px solid var(--border-color);
            border-radius: 8px;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0, 168, 120, 0.1);
        }
        
        .form-label {
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }
        
        /* Page Title */
        h1 { color: var(--text-primary); font-weight: 700; margin-bottom: 2rem; }
        h1 small { color: var(--text-secondary); }
        
        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background: rgba(0, 168, 120, 0.3);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0, 168, 120, 0.5); }
        
        /* Responsive */
        @@media (max-width: 768px) {
            .sidebar { width: 100% !important; min-height: auto; }
            .main-content { padding: 1.5rem; }
            .sidebar .nav-link { padding: 0.7rem 1rem; }
        }
    </style>
</head>
<body>
@{
    var role = Context.Session.GetString("UserRole");
    var name = Context.Session.GetString("UserName");
    var isLoggedIn = !string.IsNullOrEmpty(role);
}
<div class="d-flex" style="min-height: 100vh;">
    @if (isLoggedIn)
    {
    <div class="sidebar d-flex flex-column" style="width:260px; min-width:260px;">
        <div class="brand">
            <i class="bi bi-hospital-fill"></i>
            <span>SmartHospital</span>
        </div>
        <div class="user-info">
            <small>Logged in as</small>
            <div class="user-name">@name</div>
            <span class="badge" style="background: linear-gradient(135deg, #00A878 0%, #00D4A3 100%);">@role</span>
        </div>
        <nav class="nav flex-column flex-grow-1" style="overflow-y: auto;">
            @if (role == "Admin")
            {
                <a class="nav-link" href="/Admin"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="nav-link" href="/Admin/Departments"><i class="bi bi-building me-2"></i>Departments</a>
                <a class="nav-link" href="/Admin/Doctors"><i class="bi bi-person-badge me-2"></i>Doctors</a>
                <a class="nav-link" href="/Admin/Patients"><i class="bi bi-people me-2"></i>Patients</a>
                <a class="nav-link" href="/Admin/Appointments"><i class="bi bi-calendar-check me-2"></i>Appointments</a>
                <a class="nav-link" href="/Admin/Prescriptions"><i class="bi bi-prescription me-2"></i>Prescriptions</a>
                <a class="nav-link" href="/Admin/Bills"><i class="bi bi-receipt me-2"></i>Bills</a>
            }
            else if (role == "Doctor")
            {
                <a class="nav-link" href="/Doctor"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="nav-link" href="/Doctor/Appointments"><i class="bi bi-calendar-check me-2"></i>My Appointments</a>
            }
            else
            {
                <a class="nav-link" href="/Patient"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                <a class="nav-link" href="/Patient/BookAppointment"><i class="bi bi-calendar-plus me-2"></i>Book Appointment</a>
                <a class="nav-link" href="/Patient/Appointments"><i class="bi bi-calendar-check me-2"></i>My Appointments</a>
                <a class="nav-link" href="/Patient/Bills"><i class="bi bi-receipt me-2"></i>My Bills</a>
            }
        </nav>
        <div class="p-3 mt-auto">
            <a class="nav-link logout-link" href="/Account/Logout">
                <i class="bi bi-box-arrow-left"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>
    }
    <div class="flex-grow-1">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible m-3 mb-0" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible m-3 mb-0" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <div class="main-content">
            @RenderBody()
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
