@model List<BillViewModel>
@{ ViewData["Title"] = "Bills"; }
<h4 class="fw-bold mb-4"><i class="bi bi-receipt me-2 text-primary"></i>All Bills</h4>
<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr><th>#</th><th>Patient</th><th>Doctor</th><th>Consult Fee</th><th>Medicine</th><th>Total</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
      <tbody>
      @foreach (var b in Model)
      {
        <tr>
          <td>@b.BillId</td>
          <td>@b.PatientName</td>
          <td>Dr. @b.DoctorName</td>
          <td>₹@b.ConsultationFee.ToString("F2")</td>
          <td>₹@b.MedicineCharges.ToString("F2")</td>
          <td class="fw-bold">₹@b.TotalAmount.ToString("F2")</td>
          <td><span class="badge @(b.PaymentStatus=="Paid"?"bg-success":"bg-warning text-dark")">@b.PaymentStatus</span></td>
          <td>@b.BilledAt.ToString("dd MMM yyyy")</td>
          <td>
            @if (b.PaymentStatus == "Unpaid")
            {
              <form asp-action="MarkPaid" method="post" style="display:inline">
                <input type="hidden" name="id" value="@b.BillId"/>
                <button class="btn btn-sm btn-success"><i class="bi bi-check2 me-1"></i>Mark Paid</button>
              </form>
            }
            else { <span class="text-success"><i class="bi bi-check-circle"></i> Paid</span> }
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
