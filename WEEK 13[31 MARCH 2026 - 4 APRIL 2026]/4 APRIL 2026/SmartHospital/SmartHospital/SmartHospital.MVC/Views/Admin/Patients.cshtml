@model List<UserViewModel>
@{ ViewData["Title"] = "Patients"; }
<h4 class="fw-bold mb-4"><i class="bi bi-people me-2 text-primary"></i>Registered Patients</h4>
<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Registered</th></tr></thead>
      <tbody>
      @foreach (var p in Model)
      {
        <tr>
          <td>@p.UserId</td>
          <td class="fw-semibold">@p.FullName</td>
          <td>@p.Email</td>
          <td>@p.CreatedAt.ToString("dd MMM yyyy")</td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
