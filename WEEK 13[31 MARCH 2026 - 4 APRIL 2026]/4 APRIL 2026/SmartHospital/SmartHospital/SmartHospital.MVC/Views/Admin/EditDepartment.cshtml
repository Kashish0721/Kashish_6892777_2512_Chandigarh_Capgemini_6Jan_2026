@model DepartmentViewModel
@{ ViewData["Title"] = "Edit Department"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4">
      <h5 class="fw-bold mb-3"><i class="bi bi-pencil me-2"></i>Edit Department</h5>
      <form asp-action="EditDepartment" method="post">
        <input asp-for="DepartmentId" type="hidden"/>
        <div class="mb-3">
          <label class="form-label fw-semibold">Department Name</label>
          <input asp-for="DepartmentName" class="form-control" required/>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Description</label>
          <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">Update</button>
          <a href="/Admin/Departments" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
