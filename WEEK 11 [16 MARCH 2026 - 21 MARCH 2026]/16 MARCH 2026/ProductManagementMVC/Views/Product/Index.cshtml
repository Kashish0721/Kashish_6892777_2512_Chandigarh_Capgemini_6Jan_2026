@model List<ProductManagementMVC.Models.Product>

<div class="container mt-5">

    <h2 class="text-center mb-4">📦 Product Management</h2>

    <div class="text-end mb-3">
        <a href="/Product/Create" class="btn btn-success">➕ Add New Product</a>
    </div>

    <table class="table table-bordered table-hover text-center shadow">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>₹@p.Price</td>

                    <td>
                        <a href="/Product/Details/@p.Id" class="btn btn-info btn-sm">View</a>

                        <a href="/Product/Edit/@p.Id" class="btn btn-warning btn-sm">Edit</a>

                        <a href="/Product/Delete/@p.Id" class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">Delete</a>
                    </td>

                </tr>
            }
        </tbody>

    </table>

</div>