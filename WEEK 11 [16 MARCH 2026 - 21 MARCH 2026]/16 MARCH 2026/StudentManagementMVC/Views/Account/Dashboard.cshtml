@{
    ViewData["Title"] = "Dashboard";
}

<h2>Welcome, @ViewBag.Username 👋</h2>

<hr />

<div class="mt-3">

    <a href="/Student/Register" class="btn btn-success me-2">➕ Add Student</a>

    <a href="/Product/Index" class="btn btn-primary me-2">📦 Products</a>

    <a href="/Account/Logout" class="btn btn-danger">🚪 Logout</a>

</div>

<hr />

<h4 class="mt-4">Students List</h4>

<table class="table table-bordered mt-2">

    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Age</th>
        <th>Email</th>
    </tr>

    @if (ViewBag.Students != null)
    {
        foreach (var s in ViewBag.Students)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.Age</td>
                <td>@s.Email</td>
            </tr>
        }
    }

</table>