@model EcommerceOrderSystem.Models.OrderItem

<h2>Create OrderItem</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label>Order</label>
        <select asp-for="OrderId" asp-items="ViewBag.OrderId"></select>
    </div>

    <div>
        <label>Product</label>
        <select asp-for="ProductId" asp-items="ViewBag.ProductId"></select>
    </div>

    <div>
        <label>Quantity</label>
        <input asp-for="Quantity" />
    </div>

    <button type="submit">Create</button>
</form>