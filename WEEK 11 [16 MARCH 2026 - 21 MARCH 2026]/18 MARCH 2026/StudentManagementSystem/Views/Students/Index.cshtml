@model List<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h2 class="mb-3">Student List</h2>

<button class="btn btn-primary mb-3" onclick="openCreateModal()">Add Student</button>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Joining Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.Email</td>
                <td>@s.Course</td>
                <td>@s.JoiningDate.ToShortDateString()</td>
                <td>
                    <button class="btn btn-warning btn-sm" onclick="openEditModal(@s.Id)">Edit</button>
                    <a class="btn btn-danger btn-sm" href="/Students/Delete/@s.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Bootstrap Modal -->
<div class="modal fade" id="studentModal">
    <div class="modal-dialog">
        <div class="modal-content" id="modalContent">
        </div>
    </div>
</div>

<script>
    function openCreateModal() {
        fetch('/Students/Create')
            .then(res => res.text())
            .then(data => {
                document.getElementById('modalContent').innerHTML = data;
                new bootstrap.Modal(document.getElementById('studentModal')).show();
            });
    }

    function openEditModal(id) {
        fetch('/Students/Edit/' + id)
            .then(res => res.text())
            .then(data => {
                document.getElementById('modalContent').innerHTML = data;
                new bootstrap.Modal(document.getElementById('studentModal')).show();
            });
    }
</script>