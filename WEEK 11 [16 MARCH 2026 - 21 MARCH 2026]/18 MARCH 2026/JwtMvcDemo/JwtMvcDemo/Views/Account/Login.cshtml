@model JwtMvcDemo.Models.User

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-4">
            <div class="card shadow p-4">

                <h3 class="text-center mb-3">Login</h3>

                <form asp-action="Login" method="post">

                    <div class="mb-3">
                        <label>Username</label>
                        <input asp-for="Username" class="form-control" placeholder="Enter username" />
                    </div>

                    <div class="mb-3">
                        <label>Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Login
                    </button>

                </form>

                <!-- Error Message -->
                @if (ViewBag.Message != null)
                {
                    <p class="text-danger mt-3 text-center">
                        @ViewBag.Message
                    </p>
                }

            </div>
        </div>

    </div>
</div>