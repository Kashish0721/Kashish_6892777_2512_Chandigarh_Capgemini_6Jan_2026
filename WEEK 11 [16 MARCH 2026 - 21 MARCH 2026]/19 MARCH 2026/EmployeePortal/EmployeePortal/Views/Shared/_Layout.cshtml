<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmployeePortal</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EmployeePortal.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <!-- UPDATED NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent px-4">
            <a class="navbar-brand fw-bold text-white" href="/">🚀 EmployeePortal</a>

            <div class="ms-auto">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="me-3">👋 @User.Identity.Name</span>

                    <a class="btn btn-danger btn-sm btn-custom"
                       asp-area="Identity" asp-page="/Account/Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-success btn-sm btn-custom"
                       asp-area="Identity" asp-page="/Account/Login">Login</a>
                }
            </div>
        </nav>
    </header>

    <!-- PAGE CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - EmployeePortal -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>