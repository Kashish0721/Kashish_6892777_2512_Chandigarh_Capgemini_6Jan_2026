@page
@model EventBooking.Web.Pages.Events.CreateEventModel
@{
    ViewData["Title"] = "Create Event";
}

<div class="container py-5" style="max-width:760px">
    <a asp-page="/Events/Index" class="btn btn-outline-secondary btn-sm mb-4">
        <i class="bi bi-arrow-left me-1"></i>Back to Events
    </a>

    <div class="booking-form-card">
        <div class="booking-form-header">
            <h4 class="mb-0 fw-700"><i class="bi bi-plus-circle me-2"></i>Create New Event</h4>
            <p class="text-white-50 mb-0 small mt-1">Fill in the details to publish a new event</p>
        </div>
        <div class="p-4">
            <form id="createEventForm" novalidate>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Event Title *</label>
                        <input type="text" id="title" class="form-control" placeholder="e.g. Tech Summit 2025" required>
                        <div class="invalid-feedback">Title is required (3–200 characters).</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select id="category" class="form-select">
                            <option value="General">General</option>
                            <option value="Technology">Technology</option>
                            <option value="Music">Music</option>
                            <option value="Sports">Sports</option>
                            <option value="Business">Business</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Organizer Name</label>
                        <input type="text" id="organizerName" class="form-control" placeholder="Organization name">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Event Date & Time *</label>
                        <input type="datetime-local" id="date" class="form-control" required>
                        <div class="invalid-feedback">Please select a future date and time.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Location *</label>
                        <input type="text" id="location" class="form-control" placeholder="Venue, City" required>
                        <div class="invalid-feedback">Location is required.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Available Seats *</label>
                        <input type="number" id="availableSeats" class="form-control" min="1" max="10000" placeholder="e.g. 500" required>
                        <div class="invalid-feedback">Seats must be between 1 and 10,000.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ticket Price (₹)</label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input type="number" id="ticketPrice" class="form-control" min="0" value="0" placeholder="0 for free">
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Image URL</label>
                        <input type="url" id="imageUrl" class="form-control" placeholder="https://…">
                        <div class="form-text">Paste a direct image URL (e.g. from Unsplash)</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea id="description" class="form-control" rows="4"
                                  placeholder="Describe the event…" maxlength="2000"></textarea>
                        <div class="form-text"><span id="descCount">0</span>/2000 characters</div>
                    </div>
                </div>

                <div id="formResult" class="mt-3"></div>

                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-primary-custom px-4" id="submitBtn">
                        <i class="bi bi-check-circle me-2"></i>Publish Event
                    </button>
                    <a asp-page="/Events/Index" class="btn btn-outline-secondary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const API_BASE_URL = '@Model.ApiBaseUrl';

// Character counter
document.getElementById('description').addEventListener('input', function() {
    document.getElementById('descCount').textContent = this.value.length;
});

// Set min date to now
const dtInput = document.getElementById('date');
const now = new Date();
now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
dtInput.min = now.toISOString().slice(0, 16);

document.getElementById('createEventForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    let valid = true;

    const title    = document.getElementById('title');
    const date     = document.getElementById('date');
    const location = document.getElementById('location');
    const seats    = document.getElementById('availableSeats');

    // ── Client-side validation ────────────────────────────────────────
    [title, date, location, seats].forEach(f => {
        f.classList.remove('is-invalid', 'is-valid');
    });

    if (!title.value.trim() || title.value.length < 3) {
        title.classList.add('is-invalid'); valid = false;
    } else { title.classList.add('is-valid'); }

    if (!date.value || new Date(date.value) <= new Date()) {
        date.classList.add('is-invalid'); valid = false;
    } else { date.classList.add('is-valid'); }

    if (!location.value.trim()) {
        location.classList.add('is-invalid'); valid = false;
    } else { location.classList.add('is-valid'); }

    const seatsVal = parseInt(seats.value);
    if (!seatsVal || seatsVal < 1 || seatsVal > 10000) {
        seats.classList.add('is-invalid'); valid = false;
    } else { seats.classList.add('is-valid'); }

    if (!valid) return;

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Publishing…';

    const payload = {
        title: title.value.trim(),
        description: document.getElementById('description').value.trim(),
        date: new Date(date.value).toISOString(),
        location: location.value.trim(),
        availableSeats: seatsVal,
        ticketPrice: parseFloat(document.getElementById('ticketPrice').value) || 0,
        category: document.getElementById('category').value,
        organizerName: document.getElementById('organizerName').value.trim(),
        imageUrl: document.getElementById('imageUrl').value.trim()
    };

    try {
        const token = sessionStorage.getItem('jwt_token');
        const res = await fetch(`${API_BASE_URL}/api/events`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (res.ok) {
            document.getElementById('formResult').innerHTML =
                `<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>
                 Event "<strong>${data.title}</strong>" published successfully!
                 <a href="/Events/Details?id=${data.id}" class="alert-link ms-2">View Event →</a></div>`;
            document.getElementById('createEventForm').reset();
            document.getElementById('descCount').textContent = '0';
        } else {
            const msg = data.errors ? Object.values(data.errors).flat().join(', ') : (data.message || 'Failed to create event.');
            document.getElementById('formResult').innerHTML =
                `<div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>${msg}</div>`;
        }
    } catch(err) {
        document.getElementById('formResult').innerHTML =
            `<div class="alert alert-danger">Network error. Check API connection.</div>`;
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Publish Event';
    }
});
</script>
}
