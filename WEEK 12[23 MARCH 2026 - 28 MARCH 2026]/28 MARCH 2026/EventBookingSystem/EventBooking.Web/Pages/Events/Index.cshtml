@page
@model EventBooking.Web.Pages.Events.EventsIndexModel
@{
    ViewData["Title"] = "Browse Events";
}

<div class="py-4 border-bottom bg-white mb-4">
    <div class="container">
        <h1 class="section-heading mb-1">Browse Events</h1>
        <p class="text-muted mb-0">Find and book your next experience</p>
    </div>
</div>

<div class="container pb-5">

    <!-- ── Filter Bar ──────────────────────────────────────────────────── -->
    <div class="filter-bar d-flex flex-wrap gap-3 align-items-end">
        <div class="flex-grow-1" style="min-width:220px">
            <label class="form-label mb-1">Search</label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0"
                       placeholder="Search events, venues…" />
            </div>
        </div>
        <div style="min-width:160px">
            <label class="form-label mb-1">Category</label>
            <select id="categoryFilter" class="form-select">
                <option value="">All Categories</option>
                <option value="Technology">Technology</option>
                <option value="Music">Music</option>
                <option value="Sports">Sports</option>
                <option value="Business">Business</option>
                <option value="General">General</option>
            </select>
        </div>
        <div style="min-width:130px">
            <label class="form-label mb-1">Sort By</label>
            <select id="sortFilter" class="form-select">
                <option value="date">Date (Soonest)</option>
                <option value="price_asc">Price (Low→High)</option>
                <option value="price_desc">Price (High→Low)</option>
                <option value="seats">Seats Available</option>
            </select>
        </div>
        <button class="btn btn-primary-custom" onclick="loadEvents()">
            <i class="bi bi-funnel me-1"></i>Filter
        </button>
        <button class="btn btn-outline-secondary" onclick="resetFilters()">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
        </button>
    </div>

    <!-- ── Results info ────────────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span id="resultsInfo" class="text-muted small"></span>
        <div id="paginationTop"></div>
    </div>

    <!-- ── Events Grid ─────────────────────────────────────────────────── -->
    <div id="eventsGrid" class="row g-4">
        <div class="col-12 text-center py-5">
            <div class="spinner-custom mx-auto mb-3"></div>
            <p class="text-muted">Loading events…</p>
        </div>
    </div>

    <!-- ── Pagination ──────────────────────────────────────────────────── -->
    <div id="paginationBottom" class="d-flex justify-content-center mt-5"></div>
</div>

@section Scripts {
<script>
const API_BASE_URL = '@Model.ApiBaseUrl';
let currentPage = 1;
const PAGE_SIZE = 9;

async function loadEvents(page = 1) {
    currentPage = page;
    const search   = document.getElementById('searchInput').value.trim();
    const category = document.getElementById('categoryFilter').value;
    const sort     = document.getElementById('sortFilter').value;

    let url = `${API_BASE_URL}/api/events?page=${page}&pageSize=${PAGE_SIZE}`;
    if (search)   url += `&search=${encodeURIComponent(search)}`;
    if (category) url += `&category=${encodeURIComponent(category)}`;

    const grid = document.getElementById('eventsGrid');
    grid.innerHTML = `<div class="col-12 text-center py-5">
        <div class="spinner-custom mx-auto mb-3"></div>
        <p class="text-muted">Loading…</p></div>`;

    try {
        const res  = await fetch(url);
        const data = await res.json();

        let events = data.data || [];

        // Client-side sort
        if (sort === 'price_asc')  events.sort((a,b) => a.ticketPrice - b.ticketPrice);
        if (sort === 'price_desc') events.sort((a,b) => b.ticketPrice - a.ticketPrice);
        if (sort === 'seats')      events.sort((a,b) => (b.availableSeats - b.bookedSeats) - (a.availableSeats - a.bookedSeats));

        document.getElementById('resultsInfo').textContent =
            `Showing ${events.length} of ${data.total} events`;

        if (events.length === 0) {
            grid.innerHTML = `<div class="col-12 text-center py-5">
                <div style="font-size:4rem">🔍</div>
                <p class="text-muted mt-2">No events match your search. Try different filters.</p></div>`;
            return;
        }

        grid.innerHTML = events.map(buildCard).join('');
        renderPagination(data.total, page);

    } catch(err) {
        grid.innerHTML = `<div class="col-12 text-center py-5 text-muted">
            <i class="bi bi-wifi-off fs-2 d-block mb-2"></i>
            Failed to load events. Make sure the API server is running at <code>${API_BASE_URL}</code></div>`;
    }
}

function buildCard(e) {
    const remaining = e.availableSeats - e.bookedSeats;
    const pct = e.availableSeats > 0 ? Math.round((remaining / e.availableSeats) * 100) : 0;
    const barCls = pct < 25 ? 'low' : '';
    const price = e.ticketPrice === 0
        ? '<span class="price-tag free">FREE</span>'
        : `<span class="price-tag">₹${Number(e.ticketPrice).toLocaleString('en-IN')}</span>`;
    const catMap = { Technology:'badge-tech', Music:'badge-music', Sports:'badge-sports', Business:'badge-business' };
    const catCls = catMap[e.category] || 'badge-general';
    const isSoldOut = remaining <= 0;
    const dateStr = new Date(e.date).toLocaleDateString('en-IN',
        { weekday:'short', day:'numeric', month:'short', year:'numeric' });
    const imgFallback = 'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800';

    return `
    <div class="col-sm-6 col-lg-4">
      <div class="event-card card">
        <div class="card-img-wrapper">
          <img src="${e.imageUrl || imgFallback}" class="card-img-top" alt="${e.title}"
               onerror="this.src='${imgFallback}'">
          <span class="event-category-badge ${catCls}">${e.category}</span>
          ${isSoldOut ? '<span class="position-absolute top-0 end-0 m-2 badge bg-danger">SOLD OUT</span>' : ''}
        </div>
        <div class="card-body d-flex flex-column">
          <h6 class="card-title">${e.title}</h6>
          <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
            ${e.description}
          </p>
          <div class="event-meta mb-3">
            <div><i class="bi bi-calendar3"></i> ${dateStr}</div>
            <div class="mt-1"><i class="bi bi-geo-alt"></i> ${e.location}</div>
            <div class="mt-1"><i class="bi bi-person"></i> ${e.organizerName || 'EventHub'}</div>
          </div>
          <div class="mt-auto">
            <div class="d-flex justify-content-between mb-1">
              <small class="text-muted">${remaining} of ${e.availableSeats} seats left</small>
              <small class="fw-semibold ${pct < 25 ? 'text-danger' : 'text-success'}">${pct}%</small>
            </div>
            <div class="seats-bar mb-3">
              <div class="seats-bar-fill ${barCls}" style="width:${pct}%"></div>
            </div>
            <div class="d-flex align-items-center justify-content-between">
              ${price}
              <a href="/Events/Details?id=${e.id}"
                 class="btn btn-sm ${isSoldOut ? 'btn-outline-secondary disabled' : 'btn-primary-custom'}">
                ${isSoldOut ? 'Sold Out' : '<i class="bi bi-ticket me-1"></i>Book Now'}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>`;
}

function renderPagination(total, current) {
    const pages = Math.ceil(total / PAGE_SIZE);
    if (pages <= 1) { document.getElementById('paginationBottom').innerHTML = ''; return; }

    let html = '<nav><ul class="pagination">';
    html += `<li class="page-item ${current===1?'disabled':''}">
        <button class="page-link" onclick="loadEvents(${current-1})"><i class="bi bi-chevron-left"></i></button></li>`;
    for (let i = 1; i <= pages; i++) {
        html += `<li class="page-item ${i===current?'active':''}">
            <button class="page-link" onclick="loadEvents(${i})">${i}</button></li>`;
    }
    html += `<li class="page-item ${current===pages?'disabled':''}">
        <button class="page-link" onclick="loadEvents(${current+1})"><i class="bi bi-chevron-right"></i></button></li>`;
    html += '</ul></nav>';
    document.getElementById('paginationBottom').innerHTML = html;
}

function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('categoryFilter').value = '';
    document.getElementById('sortFilter').value = 'date';
    loadEvents(1);
}

// Debounced search
let debounceTimer;
document.getElementById('searchInput').addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => loadEvents(1), 400);
});
document.getElementById('categoryFilter').addEventListener('change', () => loadEvents(1));

loadEvents(1);
</script>
}
