@page
@model EventBooking.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <div style="font-size:5rem">⚠️</div>
    <h2 class="fw-800 mt-3">Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred. Please try again.</p>
    @if (Model.RequestId != null)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-page="/Index" class="btn btn-primary-custom mt-3">
        <i class="bi bi-house me-2"></i>Go Home
    </a>
</div>
